* {

    margin: 0px;
    font-family: Arial, Helvetica, sans-serif;

}

nav {

    width: 100%;

    height: 100px;

    display: flex;

    align-items: center;

    justify-content: center;

    gap: 30px;

    background-color: orange;

}

a {

    text-decoration: none;

    color: white;

}

.bty {

    padding: 12px;

    background-color: black;

    color: white;

    border-radius: 25px;

}

section {

    width: 100%;

    height: 100vh;

    scroll-margin-top: 70px;

}

#c1 {

    background-color: orange;

}

.texto {

    width: 600px;

    height: 350px;

    background-color: transparent;

    position: absolute;

    left: 50px;

    bottom: 10px;

}

h1 {
    color: black;

    font-size: 50px;

    margin-bottom: 10px;

}

p {

    font-size: 20px;

    margin-bottom: 10px;

}

#gpt {

    padding: 15px;

    background-color: black;

    color: white;

    border-radius: 25px;

}

.conteudo {

    width: 600px;

    height: 450px;

    background-color: transparent;

}

#c2 {

    display: flex;

    justify-content: flex-end;

    align-items: center;

}

h2 {
   color: orange;

    margin-left: 40px;

    font-size: 40px;

    margin-bottom: 20px;

}

ul {

    font-size: 20px;

}

li {

    margin-bottom: 20px;

}

.container {

    width: 1200px;

    height: 600px;

    background-color: transparent;

    display: flex;

    gap: 25px;

}

#c3 {

    display: flex;

    align-items: center;

    justify-content: center;

}

.cont {

    width: 260px;

    height: 500px;

    border-radius: 25px;

    background-color: blanchedalmond;

    margin-right: 10px;

    text-align: center;

    margin-top: 10px;
    transition: transform 0.4s ease;
    cursor: pointer;
    overflow: hidden;

}
.cont.ativo {
    transform: scale(1.5); 
    z-index: 99;
    border: 2px solid orange;
}
.video-oculto {
   /* display: none; /* Não aparece enquanto não clicar */
    width: 100%;
}
.cont.ativo .video-oculto {
    display: block;
}
h3 {
    font-size: 40px;
    color: orange;
    margin-bottom: 20px;
    margin-left: 50px;
    line-height: 1.6;

}

.fip {

    margin-bottom: 20px;

}
footer {

    background-color: orange;
    height: 300px;
}
.gta {
    width: 600px;
    height: 400px;
    background-color: transparent;
    margin-left: 50px;
}
#c4 {
    display: flex;
    justify-content: flex-start;
}
#foto-jigoro {
    width: 450px;
    height: 550px;
    position: absolute;
    left: 80px;
    top: 750px;
    display: block;
}
#uchi {
    width: 550px;
    height: 500px;
    position: relative;
    left: 110%;
    bottom: 400px;
    display: block;
}
#ipon {
    width: 600px;
    height: 500px;
    position: absolute;
    bottom: 5%;
    right: 50px;
}
h4 {
    font-size: 30px;
    margin-left: 35px;
     margin-bottom: 10px;
}
#vgi {
    position: relative;
    margin-bottom: 0px;
}
@media (max-width: 800px) {

  #ipon {
    display: none; 
  }
  #foto-jigoro {
    display: none; 
  }
  #uchi {
     display: none; 
  }

}